    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  }
