{
  "name": "atblob-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "atblob": "turbo run build --filter=atblob && node packages/cli/dist/index.js",
