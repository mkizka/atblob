{
  "name": "@atblob/core",
  "version": "0.0.1",
  "type": "module",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "eslint --fix . && prettier --write --log-level warn .",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@atproto-labs/fetch-node": "^0.3.4",
    "@atproto/identity": "^0.5.3",
    "@gyaku/di": "^3.5.0",
    "ioredis": "^5.11.1",
    "multiformats": "^14.0.4",
    "sharp": "^0.35.3",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "get-port": "7.2.0",
    "prettier": "3.9.4",
    "prettier-plugin-pkg": "0.22.1",
    "vitest": "4.1.10"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg"
    ]
  }
}
