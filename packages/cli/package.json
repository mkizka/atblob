{
  "name": "@atblob/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "bin": {
    "atblob": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "eslint --fix . && prettier --write --log-level warn .",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@atblob/core": "workspace:*",
    "@atblob/hono": "workspace:*",
    "@hono/node-server": "2.0.8",
    "arg": "5.0.2",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "get-port": "7.2.0",
    "prettier": "3.9.4",
    "prettier-plugin-pkg": "0.22.1",
    "vitest": "4.1.10"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg"
    ]
  }
}
