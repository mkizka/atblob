{
  "name": "@atblob/express",
  "version": "0.0.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "eslint --fix . && prettier --write --log-level warn .",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@atblob/core": "workspace:*",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "get-port": "7.2.0",
    "prettier": "3.9.4",
    "prettier-plugin-pkg": "0.22.1",
    "vitest": "4.1.10"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg"
    ]
  }
}
